# OpenELO - Environment Configuration

# App
PORT=8080
BASE_URL=http://localhost:8080
DEFAULT_LANG=en
# Environment identifier (empty=production, any other value=non-production environment)
APP_ENV=
# Secret key used to authenticate demo seed push requests (curl -H "X-App-Secret: ...")
APP_SECRET=

# Database
DB_TYPE=sqlite
# SQLite
DB_PATH=/var/www/html/data/openelo.db
# MySQL (only if DB_TYPE=mysql)
DB_HOST=localhost
DB_PORT=3306
DB_NAME=openelo
DB_USER=root
DB_PASSWORD=

# Email (SMTP)
SMTP_HOST=smtp.example.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
MAIL_FROM=noreply@openelo.org
MAIL_FROM_NAME=OpenELO
ADMIN_EMAIL=admin@openelo.org

# Tokens
TOKEN_EXPIRY_HOURS=72

# Elo
ELO_START=1200

# Analytics / Tracking
# HTML snippet injected inside <head> (e.g. Google Ads conversion tracking, etc.)
HEAD_CUSTOM_HTML=
# HTML snippet injected before </body> (e.g. Google Analytics, Matomo, etc.)
FOOTER_CUSTOM_HTML=
